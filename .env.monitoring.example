# Monitoring Stack Credentials
# Copy to .env.monitoring and fill in real values
# Usage: docker compose -f docker-compose.yml -f docker-compose.monitoring.yml --env-file .env.monitoring up -d

# Shared password for Prometheus basic auth + Grafana admin
MONITORING_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# Discord webhook for Grafana alerting (optional)
DISCORD_WEBHOOK_URL=
