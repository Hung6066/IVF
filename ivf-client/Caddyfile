# Caddyfile for containerized frontend (standalone SPA)
# Used inside Docker container only
# Production reverse proxy is handled by docker/caddy/Caddyfile

:80 {
	root * /srv/frontend

	# Compression
	encode gzip zstd

	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Static assets — serve directly, 404 if missing (NO SPA fallback)
	# Prevents returning index.html with text/html MIME for stale chunk requests
	@static path *.js *.css *.png *.jpg *.jpeg *.gif *.svg *.ico *.woff *.woff2 *.map
	handle @static {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# Everything else — SPA fallback → index.html
	handle {
		try_files {path} /index.html
		header Cache-Control "no-cache, no-store, must-revalidate"
		file_server
	}
}
