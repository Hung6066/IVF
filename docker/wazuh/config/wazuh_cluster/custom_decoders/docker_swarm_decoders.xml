<!--
  Custom decoders for Docker & Docker Swarm monitoring
  Mount vào manager: /var/ossec/etc/decoders/docker_swarm_decoders.xml

  full_command logs format:
    ossec: output: 'alias': {json...}

  Each decoder uses prematch to find the prefix, then
  plugin_decoder offset="after_prematch" to parse JSON payload.
  Single decoder per command (no parent/child needed).
-->

<!-- ─── Docker Swarm Services ─── -->
<decoder name="docker-swarm-services">
  <prematch>^ossec: output: 'docker-swarm-services': </prematch>
  <plugin_decoder offset="after_prematch">JSON_Decoder</plugin_decoder>
</decoder>

<!-- ─── Docker Swarm Nodes ─── -->
<decoder name="docker-swarm-nodes">
  <prematch>^ossec: output: 'docker-swarm-nodes': </prematch>
  <plugin_decoder offset="after_prematch">JSON_Decoder</plugin_decoder>
</decoder>

<!-- ─── Docker Info ─── -->
<decoder name="docker-info">
  <prematch>^ossec: output: 'docker-info': </prematch>
  <plugin_decoder offset="after_prematch">JSON_Decoder</plugin_decoder>
</decoder>

<!-- ─── Docker Containers ─── -->
<decoder name="docker-containers">
  <prematch>^ossec: output: 'docker-containers': </prematch>
  <plugin_decoder offset="after_prematch">JSON_Decoder</plugin_decoder>
</decoder>

<!-- ─── Docker Unhealthy ─── -->
<decoder name="docker-unhealthy">
