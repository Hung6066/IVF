<!--
  Custom decoders for Docker & Docker Swarm monitoring
  Mount vào manager: /var/ossec/etc/decoders/docker_swarm_decoders.xml
-->

<!-- ─── Docker Swarm Services ─── -->
<decoder name="docker-swarm-services">
  <prematch>^ossec: output: 'docker-swarm-services'</prematch>
</decoder>
<decoder name="docker-swarm-services-json">
  <parent>docker-swarm-services</parent>
  <regex offset="after_parent">(\S+)</regex>
  <order>extra_data</order>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>

