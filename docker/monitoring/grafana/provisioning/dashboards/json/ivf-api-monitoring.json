    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 25, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 94 },
      "id": 51,
      "options": { "legend": { "displayMode": "table", "calcs": ["sum", "lastNotNull"], "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Alert History (Firing)",
      "type": "timeseries",
      "targets": [
        { "expr": "ALERTS{alertstate=\"firing\"}", "legendFormat": "{{alertname}} — {{severity}}" }
      ]
