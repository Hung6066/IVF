      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(count_over_time({swarm_service=~\"ivf_api.*\"} |~ \"(?i)exception\" [$__interval]))", "legendFormat": "Exceptions" },
        { "expr": "sum(count_over_time({swarm_service=~\"ivf_api.*\"} |~ \"(?i)error\" != \"errors_total\" [$__interval]))", "legendFormat": "Errors" },
        { "expr": "sum(count_over_time({swarm_service=~\"ivf_api.*\"} |~ \"(?i)warn\" != \"warning\" [$__interval]))", "legendFormat": "Warnings" }
