    {
      "datasource": { "type": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] }, "textMode": "auto" },
      "title": "Errors (last 1h)",
      "type": "stat",
      "targets": [{ "expr": "count_over_time({swarm_service=~\"ivf_api.*\"} |~ \"(?i)(exception|error|fail|critical)\" != \"HealthCheck\" != \"errors_total\" [1h])", "legendFormat": "errors" }]
