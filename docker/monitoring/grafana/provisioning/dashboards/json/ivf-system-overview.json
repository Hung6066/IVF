    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "📊 Key Metrics (RED Method)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "reqps",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }] }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 6 },
      "id": 10,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Request Rate",
      "type": "stat",
      "targets": [{ "expr": "ivf:http_requests:rate5m or sum(rate(http_server_request_duration_seconds_count{job=\"ivf-api\"}[5m]))", "legendFormat": "req/s" }]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] },
          "min": 0, "max": 1
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 6 },
      "id": 11,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Error Rate (5xx)",
      "type": "stat",
      "targets": [{ "expr": "ivf:http_error_rate:ratio5m or (sum(rate(http_server_request_duration_seconds_count{job=\"ivf-api\", http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count{job=\"ivf-api\"}[5m])))", "legendFormat": "error %" }]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 6 },
      "id": 12,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "P95 Latency",
      "type": "stat",
      "targets": [{ "expr": "ivf:http_latency_p95:5m or histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"ivf-api\"}[5m])) by (le))", "legendFormat": "P95" }]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "decbytes",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 536870912 }, { "color": "red", "value": 838860800 }] }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 6 },
      "id": 13,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "API Memory",
      "type": "stat",
      "targets": [{ "expr": "dotnet_process_memory_working_set_bytes{job=\"ivf-api\"}", "legendFormat": "memory" }]
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 102,
      "title": "📈 Request Rate & Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 20,
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max", "lastNotNull"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "HTTP Request Rate by Status",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"ivf-api\", http_response_status_code=~\"2..\"}[5m]))", "legendFormat": "2xx Success" },
        { "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"ivf-api\", http_response_status_code=~\"3..\"}[5m]))", "legendFormat": "3xx Redirect" },
        { "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"ivf-api\", http_response_status_code=~\"4..\"}[5m]))", "legendFormat": "4xx Client Error" },
        { "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"ivf-api\", http_response_status_code=~\"5..\"}[5m]))", "legendFormat": "5xx Server Error" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max", "lastNotNull"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Response Time Percentiles",
      "type": "timeseries",
      "targets": [
        { "expr": "ivf:http_latency_p50:5m or histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=\"ivf-api\"}[5m])) by (le))", "legendFormat": "P50 (median)" },
        { "expr": "ivf:http_latency_p95:5m or histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"ivf-api\"}[5m])) by (le))", "legendFormat": "P95" },
        { "expr": "ivf:http_latency_p99:5m or histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=\"ivf-api\"}[5m])) by (le))", "legendFormat": "P99" }
      ]
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 103,
      "title": "🔍 Top Endpoints",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps", "custom": { "lineWidth": 1, "fillOpacity": 30, "showPoints": "never", "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"], "placement": "right", "sortBy": "Max", "sortDesc": true }, "tooltip": { "mode": "multi" } },
      "title": "Request Rate by Endpoint (Top 10)",
      "type": "timeseries",
      "targets": [
        { "expr": "topk(10, sum(rate(http_server_request_duration_seconds_count{job=\"ivf-api\"}[5m])) by (http_route))", "legendFormat": "{{ http_route }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"], "placement": "right", "sortBy": "Max", "sortDesc": true }, "tooltip": { "mode": "multi" } },
      "title": "Slowest Endpoints P95 (Top 10)",
      "type": "timeseries",
      "targets": [
        { "expr": "topk(10, histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"ivf-api\"}[5m])) by (le, http_route)) > 0)", "legendFormat": "{{ http_route }}" }
      ]
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 104,
      "title": "💾 API Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "decbytes", "custom": { "lineWidth": 2, "fillOpacity": 20 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "id": 40,
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max", "lastNotNull"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Process Memory",
      "type": "timeseries",
      "targets": [
        { "expr": "dotnet_process_memory_working_set_bytes{job=\"ivf-api\"}", "legendFormat": "Working Set" },
        { "expr": "dotnet_gc_last_collection_memory_committed_size_bytes{job=\"ivf-api\"}", "legendFormat": "Committed" },
        { "expr": "dotnet_gc_last_collection_heap_size_bytes{job=\"ivf-api\"}", "legendFormat": "GC Heap" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "id": 41,
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max", "lastNotNull"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": ".NET Runtime",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(dotnet_gc_collections_total{job=\"ivf-api\"}[5m])", "legendFormat": "GC Gen{{ gc_heap_generation }}/s" },
        { "expr": "dotnet_thread_pool_thread_count_total{job=\"ivf-api\"}", "legendFormat": "Threads" },
        { "expr": "dotnet_thread_pool_queue_length_total{job=\"ivf-api\"}", "legendFormat": "TP Queue" }
      ]
    }
