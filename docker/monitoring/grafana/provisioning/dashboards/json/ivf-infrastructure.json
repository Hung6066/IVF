{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🟢 Active Alerts",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": { "error": true, "firing": true, "noData": true, "normal": false, "pending": true }
      },
      "title": "Prometheus Alerts",
      "type": "alertlist",
      "targets": [{ "expr": "ALERTS{alertstate=\"firing\"}", "legendFormat": "{{ alertname }}" }]
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "📊 Prometheus Targets",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "custom": { "filterable": true }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 8 },
      "id": 2,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false },
        "sortBy": [{ "desc": false, "displayName": "Value" }]
      },
      "title": "Scrape Target Status",
      "type": "table",
      "targets": [{ "expr": "up", "legendFormat": "{{ job }} - {{ instance }}", "format": "table", "instant": true }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true }, "renameByName": { "job": "Job", "instance": "Instance", "Value": "Status", "service": "Service" } } }
      ]
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "⏱️ Prometheus Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Scrape Duration",
      "type": "timeseries",
      "targets": [
        { "expr": "scrape_duration_seconds", "legendFormat": "{{ job }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Samples Scraped",
      "type": "timeseries",
      "targets": [
        { "expr": "scrape_samples_scraped", "legendFormat": "{{ job }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 20 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 12,
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"], "placement": "bottom" } },
      "title": "Rule Evaluation Duration",
      "type": "timeseries",
      "targets": [
        { "expr": "prometheus_rule_group_duration_seconds", "legendFormat": "{{ rule_group }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "decbytes", "custom": { "lineWidth": 2, "fillOpacity": 20 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 13,
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"], "placement": "bottom" } },
      "title": "TSDB Storage",
      "type": "timeseries",
      "targets": [
        { "expr": "prometheus_tsdb_storage_blocks_bytes", "legendFormat": "Blocks" },
        { "expr": "prometheus_tsdb_wal_storage_size_bytes", "legendFormat": "WAL" }
      ]
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "📝 Loki Log Volume",
      "type": "row"
    },
    {
      "datasource": { "type": "loki" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 30, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "id": 20,
      "options": { "legend": { "displayMode": "table", "calcs": ["sum", "mean"], "placement": "right", "sortBy": "Total", "sortDesc": true }, "tooltip": { "mode": "multi" } },
      "title": "Log Volume by Service",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(count_over_time({swarm_service=~\".+\"} [$__interval])) by (swarm_service)", "legendFormat": "{{ swarm_service }}" }
      ]
    },
    {
      "datasource": { "type": "loki" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 30 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "calcs": ["sum"], "placement": "bottom" } },
      "title": "Error Log Volume",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(count_over_time({swarm_service=~\".+\"} |~ \"(?i)(error|exception|fatal|panic)\" [$__interval])) by (swarm_service)", "legendFormat": "{{ swarm_service }}" }
      ]
    },
    {
      "datasource": { "type": "loki" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 30, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "id": 22,
      "options": { "legend": { "displayMode": "table", "calcs": ["sum"], "placement": "bottom" } },
      "title": "Log Volume by Compose Service",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(count_over_time({compose_service=~\".+\"} [$__interval])) by (compose_service)", "legendFormat": "{{ compose_service }}" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ivf", "infrastructure", "alerts"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Ho_Chi_Minh",
  "title": "IVF Infrastructure & Alerts",
  "uid": "ivf-infrastructure",
  "version": 1
}
